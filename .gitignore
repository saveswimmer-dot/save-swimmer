# Save Swimmer - archivos que NO deben subirse al repo

# Sistema / editor
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*.tmp
*.bak
*.old
*.log

# Codex / estado local de trabajo
.agents/
.codex/
.codex-remote-attachments/
tmp/
work/

# Secretos, claves y configuraciones privadas
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
*.jks
secrets/
private/
credenciales/
credentials/
ngrok.yml
ngrok*.yml
*token*
*secret*

# Android / Gradle
.gradle/
build/
**/build/
captures/
local.properties
*.iml
*.ipr
*.iws

# Android Studio
.idea/
!.idea/codeStyles/
!.idea/codeStyles/*

# APK/AAB generados
**/outputs/
*.apk
*.aab

# Arduino / PlatformIO / firmware generado
.pio/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/
*.bin
*.elf
*.hex
*.map

# Node / web tooling
node_modules/
dist/
.next/
.vite/

# Python / herramientas de analisis
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Archivos grandes o empaquetados
*.zip
*.7z
*.rar
*.tar
*.gz
*.mp4
*.mov
*.avi
*.mkv

# Datos sensibles o pesados de pruebas reales
datasets/raw/
datasets/privado/
datasets/private/
backend/data/
*.sqlite
*.sqlite3
*.db

# Mantener documentos de salida pequenos; exportaciones grandes van por Drive
outputs/*.zip
outputs/*.7z
outputs/*.mp4
